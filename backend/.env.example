# TiDB Cloud / MySQL connection string
# Standard TiDB port is 4000. Example: 
# mysql://[user].root:[password]@[host]:4000/bookvault?ssl-mode=VERIFY_IDENTITY
DATABASE_URL=mysql://user:password@host:4000/dbname

# Individual fields
DB_HOST=your-tidb-host.tidbcloud.com
DB_PORT=4000
DB_NAME=bookvault
DB_USER=your-user.root
DB_PASSWORD=your-password
DB_SSL=true
# Optional: Path to CA certificate for TiDB Cloud (if required)
# DB_CA_PATH=./isrgrootx1.pem

JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

PORT=5000
NODE_ENV=development

FRONTEND_URL=https://bookvault.vercel.app

FINE_RATE_PER_DAY=2.00
BORROW_DURATION_DAYS=14
RESERVATION_EXPIRY_HOURS=48
